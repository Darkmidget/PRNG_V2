/***************************************************
  Conway's Game of Life Display
  For Adafruit Feather M4 Express + HX8357D FeatherWing
  
  Displays animated Game of Life patterns seeded from
  a random 16-bit number (0-65535).
  
  Open Serial Monitor at 115200 baud and press reset.
 ****************************************************/

#include <SPI.h>
#include <Arduino.h>
#include "Adafruit_GFX.h"
#include "Adafruit_HX8357.h"

// Pin definitions for Feather M4 + HX8357D FeatherWing
#define TFT_CS   9
#define TFT_DC   10
#define TFT_RST  -1

// Create display object
Adafruit_HX8357 tft = Adafruit_HX8357(TFT_CS, TFT_DC, TFT_RST);

// Game grid dimensions
#define COLS 40
#define ROWS 60
#define CELL_SIZE 8

// Display dimensions
#define DISPLAY_WIDTH 320
#define DISPLAY_HEIGHT 480

// Grid data - using uint8_t to store alive (1) or dead (0) cells
uint8_t grid[ROWS][COLS];
uint8_t nextGrid[ROWS][COLS];
uint32_t generation = 0;

// Color definitions (16-bit RGB565)
#define COLOR_BG     0x0000    // Black
#define COLOR_ALIVE  0xFFFF    // White
#define COLOR_BORDER 0x4208    // Dark gray
#define COLOR_TEXT   0xFFE0    // Yellow

// ========================================
// GAME OF LIFE LOGIC
// ========================================

void initializeGrid(uint16_t seed) {
  memset(grid, 0, sizeof(grid));
  generation = 0;
  
  Serial.print(F("Initializing with seed: "));
  Serial.println(seed);
  
  // Use seed to create pseudo-random positions
  uint16_t rng = seed;
  
  // Place gliders and blinkers at pseudo-random positions based on seed
  // Glider 1
  uint8_t x1 = (rng % (COLS - 3));
  rng = rng * 1103515245 + 12345;  // Simple LCG
  uint8_t y1 = (rng % (ROWS - 3));
  rng = rng * 1103515245 + 12345;
  
  grid[y1][x1] = 1;
  grid[y1+1][x1+1] = 1;
  grid[y1+2][x1] = 1;
  grid[y1+2][x1+1] = 1;
  grid[y1+2][x1+2] = 1;
  
  // Glider 2
  rng = rng * 1103515245 + 12345;
  uint8_t x2 = (rng % (COLS - 3));
  rng = rng * 1103515245 + 12345;
  uint8_t y2 = (rng % (ROWS - 3)) + 10;  // Offset vertically
  rng = rng * 1103515245 + 12345;
  
  grid[y2][x2] = 1;
  grid[y2+1][x2+1] = 1;
  grid[y2+2][x2] = 1;
  grid[y2+2][x2+1] = 1;
  grid[y2+2][x2+2] = 1;
  
  // Blinker (period 2 oscillator)
  rng = rng * 1103515245 + 12345;
  uint8_t x3 = (rng % COLS);
  rng = rng * 1103515245 + 12345;
  uint8_t y3 = (rng % ROWS);
  
  grid[y3][x3] = 1;
  grid[y3][x3+1] = (x3+1 < COLS) ? 1 : 0;
  grid[y3][x3+2] = (x3+2 < COLS) ? 1 : 0;
  
  Serial.println(F("Grid initialized with patterns"));
}

// Count living neighbors for given cell
uint8_t countNeighbors(uint8_t x, uint8_t y) {
  uint8_t count = 0;
  
  for (int8_t dy = -1; dy <= 1; dy++) {
    for (int8_t dx = -1; dx <= 1; dx++) {
      if (dx == 0 && dy == 0) continue;
      
      int16_t nx = x + dx;
      int16_t ny = y + dy;
      
      // Wrap around edges (toroidal topology)
      if (nx < 0) nx += COLS;
      if (nx >= COLS) nx -= COLS;
      if (ny < 0) ny += ROWS;
      if (ny >= ROWS) ny -= ROWS;
      
      count += grid[ny][nx];
    }
  }
  
  return count;
}

// Update game state - Conway's Game of Life rules
void updateGame() {
  // Copy current to next
  memcpy(nextGrid, grid, sizeof(grid));
  
  // Apply rules
  for (uint8_t y = 0; y < ROWS; y++) {
    for (uint8_t x = 0; x < COLS; x++) {
      uint8_t neighbors = countNeighbors(x, y);
      uint8_t alive = grid[y][x];
      
      if (alive) {
        // Survival: 2-3 neighbors
        nextGrid[y][x] = (neighbors == 2 || neighbors == 3) ? 1 : 0;
      } else {
        // Birth: exactly 3 neighbors
        nextGrid[y][x] = (neighbors == 3) ? 1 : 0;
      }
    }
  }
  
  // Swap grids
  memcpy(grid, nextGrid, sizeof(grid));
  generation++;
}

// ========================================
// DISPLAY RENDERING
// ========================================

void renderDisplay() {
  // Clear display to black
  tft.fillScreen(COLOR_BG);
  
  // Draw border
  tft.drawRect(0, 0, DISPLAY_WIDTH, DISPLAY_HEIGHT, COLOR_BORDER);
  
  // Draw game grid
  for (uint8_t y = 0; y < ROWS; y++) {
    for (uint8_t x = 0; x < COLS; x++) {
      if (grid[y][x]) {
        uint16_t px = x * CELL_SIZE;
        uint16_t py = y * CELL_SIZE;
        tft.fillRect(px, py, CELL_SIZE, CELL_SIZE, COLOR_ALIVE);
      }
    }
  }
  
  // Draw info panel at bottom
  uint16_t infoY = ROWS * CELL_SIZE + 10;
  tft.setTextColor(COLOR_TEXT, COLOR_BG);
  tft.setTextSize(1);
  tft.setCursor(5, infoY);
  tft.print(F("Gen: "));
  tft.println(generation);
}

// ========================================
// MAIN SETUP
// ========================================

void setup() {
  Serial.begin(115200);
  while (!Serial) delay(10);
  
  delay(500);
  Serial.println();
  Serial.println(F("========================================"));
  Serial.println(F("Game of Life - Feather M4 + HX8357D"));
  Serial.println(F("========================================"));
  
  // Initialize display
  Serial.println(F("Initializing display..."));
  tft.begin(HX8357D);
  Serial.println(F("Display initialized"));
  
  // Set rotation and clear
  tft.setRotation(0);
  tft.fillScreen(COLOR_BG);
  
  // Generate seed from analog noise
  randomSeed(analogRead(A2));
  uint16_t seed = random(65536);
  
  Serial.print(F("Random seed: "));
  Serial.println(seed);
  
  // Initialize game with seed
  initializeGrid(seed);
  
  // First render
  Serial.println(F("Rendering first frame..."));
  renderDisplay();
  
  Serial.println(F("Setup complete! Game starting..."));
}

// ========================================
// MAIN LOOP
// ========================================

void loop() {
  // Update game logic
  updateGame();
  
  // Render to display every 3 generations for speed effect
  if (generation % 3 == 0) {
    renderDisplay();
  }
  
  // Delay for animation speed
  delay(100);
}
